# Copy to .env (DO NOT COMMIT .env) and fill in your keys.
#
# OpenRouter (required for tools/generate_keyfacts_images_openrouter.py)
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=
# Default image model for OpenRouter image generation helper (optional)
# Recommended: sourceful/riverflow-v2-fast for best results, but you can experiment with other models available on OpenRouter (https://openrouter.ai/models?type=image) or your own custom model.
OPENROUTER_IMAGE_MODEL=sourceful/riverflow-v2-fast
# Default modalities for OpenRouter image generation helper (optional)
OPENROUTER_IMAGE_MODALITIES=image
OPENROUTER_IMAGE_SIZE=1K
OPENROUTER_IMAGE_ASPECT_RATIO=
#
# Optional: enable Key Facts image generation during the workflow
# Set to 1 to enable, 0 to disable (default: 0)
CBLM_GENERATE_IMAGES=0
#
# Optional: OpenAI (only if you choose tools/generate_keyfacts_images_openai.py)
OPENAI_API_KEY=
